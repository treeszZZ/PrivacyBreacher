<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvMonthYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2025年1月"
            android:textColor="#1A2A3A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnPrevMonth"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_left"
            android:background="@null"
            android:contentDescription="上个月" />

        <ImageButton
            android:id="@+id/btnNextMonth"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_right"
            android:background="@null"
            android:contentDescription="下个月" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView style="@style/CalendarWeekDay" android:text="日" />
        <TextView style="@style/CalendarWeekDay" android:text="一" />
        <TextView style="@style/CalendarWeekDay" android:text="二" />
        <TextView style="@style/CalendarWeekDay" android:text="三" />
        <TextView style="@style/CalendarWeekDay" android:text="四" />
        <TextView style="@style/CalendarWeekDay" android:text="五" />
        <TextView style="@style/CalendarWeekDay" android:text="六" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/calendarGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:columnCount="7" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="4dp">

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="#4A90D9"
            android:layout_marginEnd="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="≤ 阈值"
            android:textColor="#1A2A3A"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> 阈值"
            android:textColor="#1A2A3A"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="#E8EEF2"
            android:layout_marginEnd="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="无记录"
            android:textColor="#1A2A3A"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
